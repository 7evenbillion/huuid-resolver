# Supabase (shared Cedimaker ecosystem project — huuid_ table prefix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side ONLY. Never expose to the client. Never commit.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resolver version reported in didResolutionMetadata and audit rows
HUUID_RESOLVER_VERSION=1.0.0
